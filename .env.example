# ============================================================================
# Alta Panel - variables de entorno
# Copia este archivo a .env.local para desarrollo local y rellena los valores.
# En produccion se configuran en Vercel (Project Settings > Environment Variables).
# NUNCA subas .env.local al repositorio.
# ============================================================================

# --- Base de datos (Neon / Vercel Postgres) ---
# Cadena "pooled" (con -pooler en el host). La usa la app en runtime.
DATABASE_URL="postgres://usuario:password@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# Cadena directa (sin -pooler). La usan solo las migraciones.
DATABASE_URL_UNPOOLED="postgres://usuario:password@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# --- Guesty Open API (OAuth2 client credentials) ---
# Solo servidor. Nunca se exponen al cliente.
GUESTY_CLIENT_ID=""
GUESTY_CLIENT_SECRET=""

# --- Acceso al panel (v1: contrasena compartida) ---
DASHBOARD_PASSWORD=""
# Secreto para firmar la cookie de sesion. Genera uno con: openssl rand -base64 48
SESSION_SECRET=""

# --- Cron ---
# Secreto que valida que la peticion viene del cron de Vercel.
CRON_SECRET=""

# --- Google Sheet publicado como CSV ---
# File > Share > Publish to web > pestana concreta > formato CSV.
COSTES_CSV_URL=""
UNIDADES_CSV_URL=""

# Zona horaria de referencia para el calculo de meses y "hoy".
TZ="Europe/Madrid"
